{
  "name": "dbschema",
  "private": true,
  "type": "module",
  "scripts": {
    "push": "dotenv -e .env.dev -- drizzle-kit push",
    "push:dev": "dotenv -e .env.dev -- drizzle-kit push",
    "push:prd": "dotenv -e .env.prd -- drizzle-kit push",
    "generate": "dotenv -e .env.dev -- drizzle-kit generate",
    "studio": "dotenv -e .env.dev -- drizzle-kit studio",
    "studio:dev": "dotenv -e .env.dev -- drizzle-kit studio",
    "studio:prd": "dotenv -e .env.prd -- drizzle-kit studio",
    "format": "prettier --write . --ignore-path ../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../.prettierignore"
  },
  "dependencies": {
    "drizzle-orm": "^0.39.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  }
}
