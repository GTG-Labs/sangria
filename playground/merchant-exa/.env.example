# Sangria merchant API key (production key — running on Base mainnet for this demo)
SANGRIA_SECRET_KEY=sg_live_...

# Sangria backend URL. Defaults to http://localhost:8080 for local dev.
# Point at the deployed Sangria backend for the demo.
SANGRIA_URL=https://api.getsangria.com

# Exa API key (from https://exa.ai dashboard). Required.
EXA_API_KEY=

# Optional: server port. Defaults to 4005.
PORT=4005
