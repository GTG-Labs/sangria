# Private key for the agent/buyer wallet (hex with 0x prefix).
# Must have USDC + ETH on Base Sepolia.
#
# To export from CDP using the existing playground wallet:
#   cd playground && uv run python -c "
#   import asyncio
#   from wallet import get_cdp_client
#   async def main():
#       client = get_cdp_client()
#       key = await client.evm.export_account(address='YOUR_ADDRESS')
#       print(f'0x{key}')
#       await client.close()
#   asyncio.run(main())
#   "
PRIVATE_KEY=0x...

# Merchant server URL (default: Express on port 4001)
MERCHANT_URL=http://localhost:4001