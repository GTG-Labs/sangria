{
  "name": "@sangria/comprehensive-test-suite",
  "version": "1.0.0",
  "description": "Comprehensive testing suite for Sangria SDK with full coverage and CI/CD",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "test": "pnpm test:unit",
    "test:all": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "pnpm test:unit:ts && pnpm test:unit:py",
    "test:unit:ts": "vitest run unit/typescript/ --reporter=verbose",
    "test:unit:py": "cd ../sdk/python && source venv/bin/activate && cd ../../tests && python -m pytest unit/python/ -v",
    "test:e2e": "vitest run e2e/ --reporter=verbose",
    "test:ci": "pnpm lint && pnpm test:unit && pnpm coverage:check",
    "test:quick": "pnpm test:unit",
    "test:watch": "vitest watch",
    "lint": "pnpm lint:ts",
    "lint:ts": "cd ../sdk/sdk-typescript && pnpm lint",
    "lint:fix": "pnpm lint:fix:ts && pnpm lint:fix:py",
    "lint:fix:ts": "cd ../sdk/sdk-typescript && pnpm lint:fix",
    "lint:fix:py": "cd ../sdk/python && black . && isort .",
    "coverage": "pnpm coverage:unit",
    "coverage:unit": "concurrently \"pnpm coverage:unit:ts\" \"pnpm coverage:unit:py\"",
    "coverage:unit:ts": "cd ../sdk/sdk-typescript && pnpm test:coverage",
    "coverage:unit:py": "cd ../sdk/python && source venv/bin/activate && cd ../../tests && python -m pytest unit/python/ --cov=sangria_sdk --cov-report=xml",
    "coverage:check": "vitest run --coverage --reporter=verbose",
    "dev:setup": "pnpm dev:setup:ts && pnpm dev:setup:py",
    "dev:setup:ts": "cd ../sdk/sdk-typescript && pnpm install",
    "dev:setup:py": "cd ../sdk/python && python -m venv venv && source venv/bin/activate && pip install -e . && pip install pytest pytest-cov pytest-asyncio",
    "dev:services": "echo 'No Docker services needed - using MockSangriaServer'",
    "dev:services:stop": "echo 'No Docker services to stop'",
    "clean": "pnpm clean:coverage && pnpm clean:artifacts",
    "clean:coverage": "rm -rf coverage/ ../sdk/*/coverage/ ../sdk/*/htmlcov/ ../sdk/*/.coverage",
    "clean:artifacts": "rm -rf e2e/results/ e2e/screenshots/ e2e/videos/",
    "precommit": "pnpm lint && pnpm test:quick",
    "prepush": "pnpm test:all && pnpm coverage:check",
    "release:check": "pnpm test:ci && pnpm security:audit",
    "security:audit": "cd ../sdk/sdk-typescript && pnpm audit"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "^4.1.3",
    "concurrently": "^8.2.2",
    "express": "^4.18.2",
    "fastify": "^5.8.3",
    "@hono/node-server": "^1.19.13",
    "hono": "^4.12.12",
    "vite": "^7.0.0",
    "vitest": "^4.1.3"
  },
  "keywords": [
    "sangria",
    "sdk",
    "testing",
    "coverage",
    "ci-cd",
    "payments",
    "web3"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/sangria-net.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/sangria-net/issues"
  },
  "homepage": "https://github.com/your-org/sangria-net#readme",
  "author": "Sangria Network",
  "license": "MIT",
  "dependencies": {}
}